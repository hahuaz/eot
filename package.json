{
  "name": "test",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "dev:vscode": "echo 'to run the \"Start Dev Servers\" VS Code task press (Ctrl+Shift+B)'",
    "dev": "concurrently \"pnpm dev:backend\" \"pnpm dev:web\"",
    "dev:backend": "tsx watch src",
    "dev:web": "cd client-web && pnpm dev",
    "test": "vitest run",
    "test:watch": "vitest",
    "dev:scrape": "cross-env NODE_ENV=development tsx watch src/scripts/daily-scrape.ts",
    "format": "prettier --write .",
    "prepare": "husky",
    "check:ts": "pnpm -w exec tsc --noEmit && pnpm -w exec tsc --noEmit --project client-web/tsconfig.json",
    "check:lint": "oxlint",
    "check:format": "prettier --check .",
    "check:all": "pnpm check:ts && pnpm check:lint && pnpm check:format"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@11.10.0",
  "dependencies": {
    "cors": "^2.8.6",
    "csv": "^6.5.1",
    "csv-writer": "^1.6.0",
    "dotenv": "^16.6.1",
    "express": "^5.2.1",
    "googleapis": "^150.0.1",
    "papaparse": "^5.5.3",
    "puppeteer": "^24.43.1",
    "tsx": "^4.22.3"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^26.1.0",
    "@types/papaparse": "^5.5.2",
    "add": "^2.0.6",
    "concurrently": "^10.0.3",
    "cross-env": "^10.1.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "oxlint": "^1.67.0",
    "pnpm": "^11.10.0",
    "prettier": "^3.9.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  },
  "lint-staged": {
    "**/*.{js,ts,tsx,json,md}": "prettier --write",
    "**/*.{js,ts,tsx}": "oxlint",
    "client-web/**/*.{ts,tsx}": "bash -c 'pnpm -w exec tsc --noEmit --project client-web/tsconfig.json'",
    "src/**/*.{ts,tsx}": "bash -c 'pnpm -w exec tsc --noEmit'"
  },
  "engines": {
    "node": ">=20 <27"
  }
}
